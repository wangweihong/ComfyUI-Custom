    "curves=red='0/0.01 0.25/0.24 0.50/0.53 0.75/0.79 1/1':green='0/0.01 0.25/0.23 0.50/0.50 0.75/0.76 1/1':blue='0/0.025 0.25/0.23 0.50/0.48 0.75/0.73 1/0.99'"
  ],
  "output_args": [
    "-preset",
    "medium",
    "-color_range",
    "tv",
    "-colorspace",
    "bt709",
    "-color_primaries",
    "bt709",
    "-color_trc",
    "bt709"
  ],
  "preview_style": {
    "filter": "contrast(1.05) saturate(1.06) brightness(1.01)",
    "background": "rgba(16,22,30,0.70)",
    "border": "1px solid rgba(96,188,220,0.34)",
    "box_shadow": "0 0 0 1px rgba(255,156,92,0.08) inset"
