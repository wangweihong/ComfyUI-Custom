{
  "display_name": "h264-mp4电影质感-3暖棕胶片",
  "extension": "mp4",
  "video_codec": "libx264",
  "pix_fmt": "yuv420p",
  "audio_codec": "aac",
  "audio_bitrate": "192k",
  "movflags": "+faststart",
  "dim_alignment": 2,
  "input_color_depth": "8bit",
  "video_filters": [
    "eq=contrast=1.03:brightness=0.006:saturation=1.02:gamma=1.01",
    "colorbalance=rs=0.024:gs=0.006:bs=-0.010:rm=0.020:gm=0.004:bm=-0.008:rh=0.016:gh=0.006:bh=0.000",
    "curves=red='0/0.018 0.25/0.26 0.50/0.54 0.75/0.80 1/1':green='0/0.014 0.25/0.24 0.50/0.50 0.75/0.75 1/1':blue='0/0.012 0.25/0.22 0.50/0.47 0.75/0.71 1/0.98'"
  ],
  "output_args": [
    "-preset",
    "medium",
    "-color_range",
    "tv",
    "-colorspace",
    "bt709",
    "-color_primaries",
    "bt709",
    "-color_trc",
    "bt709"
  ],
  "preview_style": {
    "filter": "contrast(1.03) saturate(1.03) brightness(1.02)",
    "background": "rgba(24,20,18,0.72)",
    "border": "1px solid rgba(214,168,116,0.34)",
    "box_shadow": "0 0 0 1px rgba(255,214,164,0.08) inset"
  }
}